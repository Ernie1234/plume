generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TweetType {
  TWEET
  REPLY
  RETWEET
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
}

enum NotificationType {
  LIKE
  RETWEET
  FOLLOW
  REPLY
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)

  bio       String?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tweets    Tweet[]
  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  likes     Like[]
  bookmarks Bookmark[]

  notifications Notification[]
  refreshTokens RefreshToken[]
  timelines     Timeline[]
  retweets      Retweet[]
}

model Tweet {
  id      String    @id @default(uuid())
  content String
  type    TweetType @default(TWEET)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  parentId String?
  parent   Tweet?  @relation("TweetReplies", fields: [parentId], references: [id])

  replies Tweet[] @relation("TweetReplies")

  media    Media[]
  hashtags Hashtag[]

  likes     Like[]
  bookmarks Bookmark[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tweetMetrics  TweetMetrics[]
  timelines     Timeline[]
  tweetHashtags TweetHashtag[]
  retweets      Retweet[]

  @@index([authorId])
  @@index([createdAt])
}

model Follow {
  id String @id @default(uuid())

  followerId  String
  followingId String

  follower  User @relation("followers", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Like {
  id String @id @default(uuid())

  userId  String
  tweetId String

  user  User  @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, tweetId])
  @@index([tweetId])
}

model Bookmark {
  id String @id @default(uuid())

  userId  String
  tweetId String

  user  User  @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, tweetId])
  @@index([tweetId])
}

model Media {
  id String @id @default(uuid())

  tweetId String
  tweet   Tweet  @relation(fields: [tweetId], references: [id])

  url  String
  type MediaType

  createdAt DateTime @default(now())
}

model Hashtag {
  id   String @id @default(uuid())
  name String @unique

  tweets        Tweet[]
  tweetHashtags TweetHashtag[]
}

model TweetHashtag {
  tweetId   String
  hashtagId String

  tweet   Tweet   @relation(fields: [tweetId], references: [id])
  hashtag Hashtag @relation(fields: [hashtagId], references: [id])

  @@id([tweetId, hashtagId])
}

model Notification {
  id String @id @default(uuid())

  userId  String
  actorId String?

  type NotificationType

  tweetId String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id     String @id
  userId String

  user User @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model TweetMetrics {
  tweetId String @id

  likesCount    Int @default(0)
  repliesCount  Int @default(0)
  retweetsCount Int @default(0)

  tweet Tweet @relation(fields: [tweetId], references: [id])

  @@index([likesCount])
}

model Timeline {
  id String @id @default(uuid())

  userId  String
  tweetId String

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  @@index([userId, createdAt])
  @@index([tweetId])
}

model Retweet {
  id String @id @default(uuid())

  userId  String
  tweetId String

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  @@unique([userId, tweetId])
  @@index([tweetId])
}
